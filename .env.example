# Server
# x402-jpycダッシュボードで発行したAPIキー（受取アドレスに紐付き）
# Dashboard: https://x402-jpyc.vercel.app/dashboard
X402_API_KEY=jpyc_sk_...

# ファシリテーターURL（ダッシュボードで確認）
X402_FACILITATOR_URL=https://...

# Client
# JPYCで支払うウォレットの秘密鍵（本番では使わないこと）
PRIVATE_KEY=0x...

# クライアントが接続するサーバーURL（省略可）
SERVER_URL=http://localhost:3000
